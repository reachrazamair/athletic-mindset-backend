# Copy this to .env:  cp .env.example .env
# NEVER commit .env to git

APP_NAME=Athletic Mindset API
DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/athletic_mindset
# The SECRET_KEY is the password used to sign JWT tokens. When the backend creates a token, it uses this key to "stamp" it.
SECRET_KEY=change-me-to-a-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=["http://localhost:3000"]

# Base URL of the Next.js frontend — used to build links inside emails
FRONTEND_URL=http://localhost:3000

# Email (Resend). Leave RESEND_API_KEY empty in local dev — emails will be printed to the terminal instead of actually being sent.
RESEND_API_KEY=
EMAIL_FROM=Athletic Mindset <onboarding@resend.dev>
