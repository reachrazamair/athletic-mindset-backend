# ============================================
# BACKEND ENVIRONMENT — TEMPLATE
# ============================================
# Copy this to .env:  cp .env.example .env
# Every value the app reads lives here — change it in one place.

# --- App ---
APP_NAME=Athletic Mindset API          # Display name of the API
DEBUG=true                             # true = verbose logs + emails printed to console

# --- Database ---
# Postgres connection (matches docker-compose.yml for local dev)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/athletic_mindset

# --- Auth / tokens ---
SECRET_KEY=change-me-to-a-random-string-in-production   # Signs all JWTs — use a strong random value in prod
ALGORITHM=HS256                        # JWT signing algorithm
ACCESS_TOKEN_EXPIRE_MINUTES=10080      # Login session length (7 days)
RESET_TOKEN_EXPIRE_MINUTES=30          # Password-reset link lifetime
VERIFY_TOKEN_EXPIRE_MINUTES=1440       # Email-verification link lifetime (24h)

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"] # Frontend URLs allowed to call the API

# --- Frontend ---
FRONTEND_URL=http://localhost:3000     # Base URL used to build links inside emails

# --- Email (Resend) ---
RESEND_API_KEY=                        # Empty = emails printed to console; set to send for real
EMAIL_FROM=Athletic Mindset <onboarding@resend.dev>   # Sender; must be a verified domain in prod

# --- Billing (Stripe) ---
# Elite plan only — Free is granted directly, no Stripe involved.
STRIPE_SECRET_KEY=                     # Developers > API keys > Secret key
STRIPE_WEBHOOK_SECRET=                 # Developers > Webhooks > your endpoint > Signing secret
STRIPE_PRICE_ID_MONTHLY=               # Elite product's monthly recurring Price ID
STRIPE_PRICE_ID_YEARLY=                # Elite product's yearly recurring Price ID
